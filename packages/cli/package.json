    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --passWithNoTests"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "@types/node": "^25.3.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@starktech/core": "*",
    "commander": "^14.0.3"
  }
}
