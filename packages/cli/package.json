{
  "name": "@starktech/velo",
  "description": "CLI for velo",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "velo": "dist/main.js"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
